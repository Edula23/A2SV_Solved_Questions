from collections import defaultdict
n, k =  map(int, input().split())
nums = list(map(int, input().split()))
left = 0
freq = defaultdict(int)
count = 0
diff = 0
for right in range(n): 
    if freq[nums[right]] == 0:
        diff+=1
    freq[nums[right]]+=1
    while diff > k:
        freq[nums[left]]-=1
        if  freq[nums[left]] == 0:
            diff -= 1
        left+=1
    count += right - left + 1
print(count)
